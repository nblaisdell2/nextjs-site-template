{
  "name": "budget-app",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "migrate": "node --env-file-if-exists=.env db/migrate.mjs",
    "db:ensure": "node --env-file-if-exists=.env db/ensure-database.mjs",
    "setup": "pwsh -NoProfile -ExecutionPolicy Bypass -File ./scripts/setup-local.ps1",
    "template:init": "pwsh -NoProfile -ExecutionPolicy Bypass -File ./scripts/init-from-template.ps1",
    "aws:setup": "pwsh -NoProfile -ExecutionPolicy Bypass -File ./scripts/setup-aws.ps1",
    "aws:bootstrap": "pwsh -NoProfile -ExecutionPolicy Bypass -File ./scripts/bootstrap-backend.ps1",
    "aws:deploy": "pwsh -NoProfile -ExecutionPolicy Bypass -File ./scripts/build-and-push.ps1",
    "aws:migrate": "pwsh -NoProfile -ExecutionPolicy Bypass -File ./scripts/run-migrations.ps1",
    "aws:secrets": "pwsh -NoProfile -ExecutionPolicy Bypass -File ./scripts/set-deploy-secrets.ps1",
    "aws:destroy": "pwsh -NoProfile -ExecutionPolicy Bypass -File ./scripts/destroy-all.ps1 -DeleteSnapshots -DeleteStateBucket"
  },
  "dependencies": {
    "next": "15.3.1",
    "pg": "^8.13.1",
    "react": "19.1.0",
    "react-dom": "19.1.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "@types/pg": "^8.11.10",
    "@types/react": "^19.1.0",
    "@types/react-dom": "^19.1.0",
    "eslint": "^9.17.0",
    "eslint-config-next": "15.3.1",
    "typescript": "^5.7.2"
  }
}
