# Copy to .env for local development.
#
# Local Postgres (e.g. `docker run -e POSTGRES_PASSWORD=postgres -p 5432:5432 postgres:16`):
DATABASE_URL=postgres://postgres:postgres@localhost:5432/postgres
DATABASE_SSL=disable

# In AWS, DATABASE_URL is injected by ECS from Secrets Manager and TLS is
# verified via the bundled RDS CA — you do NOT set these there.
#
# Tip: `npm run setup` writes this file for you (prompts for the password).
